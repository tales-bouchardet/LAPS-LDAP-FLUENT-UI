<Window x:Class="WpfFluentApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LAPS UI" Height="320" Width="500"
    MinHeight="320" MaxHeight="320" MinWidth="500" MaxWidth="500"
    ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Margin="12,6,12,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" >
            
                        <TextBlock Text="Hostname:" Foreground="#777777" FontSize="13" Margin="0,0,0,4"/>
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HostnameTextBox" Foreground="#ddd" VerticalAlignment="Center" Grid.Column="0" MinWidth="200" FontSize="15" Padding="6,5"/>
                            <Button x:Name="SearchButton" Grid.Column="1" Foreground="#ddd" Content="Buscar" Width="90" Margin="8,0,0,0" FontSize="15" Click="SearchButton_Click"/>
                        </Grid>
            
            <TextBlock Text="Senha:" Foreground="#777777" FontSize="13" Margin="0,8,0,4" />
            <TextBox x:Name="SenhaTextBox" Foreground="#ddd" VerticalAlignment="Center" FontSize="15" Padding="6,5" IsReadOnly="True"/>

            
            <TextBlock Text="Expira:" Foreground="#777777" FontSize="13" Margin="0,8,0,4" />
            <TextBox x:Name="ExpiraTextBox" Foreground="#ddd" VerticalAlignment="Center" FontSize="15" Padding="6,5" IsReadOnly="True" IsEnabled="False"/>

            
            <Grid HorizontalAlignment="Stretch" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Status:" Foreground="#777777" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="StatusTextBox" Foreground="#ddd" FontSize="15" Padding="6,5" IsReadOnly="True" IsEnabled="False" Grid.Column="0"/>
                </StackPanel>
                <Button x:Name="AtivarButton" Content="Ativar" Grid.Column="1" Foreground="#ddd" Width="75" Margin="0,21,0,0" FontSize="15" Click="AtivarButton_Click" IsEnabled="False"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Última modificação:" Foreground="#777777" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="UltimaModTextBox" Foreground="#ddd" FontSize="15" Padding="6,5" IsReadOnly="True" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        
        <Border Grid.Row="1" Background="#000" Height="20" CornerRadius="0,0,6,6" Margin="0,0,0,0" Opacity="0.2"></Border>
            <TextBlock Grid.Row="1"
                       x:Name="FooterLoadingTextBlock"
                       Text="carregando..."
                       Foreground="#777777"
                       FontSize="12"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="6,0,0,0"
                       Visibility="Collapsed"/>
            <TextBlock Grid.Row="1"
                       Text="Versão 1.0.0"
                       Foreground="#555"
                       FontSize="12"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,6,0"/>
        
    </Grid>
</Window>
